<Window x:Class="StageManagementSystem.Views.SyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sync met OnStage" Height="800" Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Gray100}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Information -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryColor}" Padding="16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Log in bij OnStage en navigeer naar het dashboard. Klik vervolgens op 'Synchroniseer' om de statussen over te nemen." Foreground="White" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- WebView2 Browser -->
        <wv2:WebView2 Grid.Row="1" x:Name="Browser" Source="https://onstage.xebic.com/default.aspx#4661613542918772/DashboardAttendant/" />

        <!-- Action Bar -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" Padding="16" BorderBrush="{DynamicResource Gray200}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" Grid.Column="0" Text="Klaar om in te loggen..." VerticalAlignment="Center" Foreground="{DynamicResource Gray600}" TextWrapping="Wrap" Margin="0,0,16,0"/>

                <Button Grid.Column="1" Content="Annuleer" Width="100" Margin="0,0,12,0" Style="{StaticResource BtnSecondary}" Click="Cancel_Click"/>
                
                <Button Grid.Column="2" Width="160" Style="{StaticResource BtnPrimary}" Click="Sync_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16" Foreground="White"/>
                        <TextBlock Text="Synchroniseer" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
